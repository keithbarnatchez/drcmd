Package: drcmd
Title: Doubly-Robust Causal Inference with Missing Data
Version: 0.0.0.9000
Authors@R: c(
    person("Keith", "Barnatchez",
           email = "keithbarnatchez@gmail.com",
           role = c("aut", "cre"),
           comment = c(ORCID = "0000-0002-1451-9335")),
    person("Griffin", "DesRoches",
           role = "aut")
